{
  "flow_id": "environmental-enforcement-flow",
  "title": "环保执法证据链流程（全领域通用）",
  "version": "1.0.0",
  "nodes": [
    {"id": "intake", "type": "input.user_need", "title": "线索受理（投诉/举报/在线监测预警/上级交办）"},
    {"id": "screening", "type": "judgment.rule", "title": "初筛/管辖/立案"},
    {"id": "inspect_prep", "type": "flow.stage_task_candidate", "title": "现场检查准备（核排污许可/历史监测/检查清单）"},
    {"id": "credentials", "type": "flow.stage_task_candidate", "title": "出示执法证件/告知权利/全过程记录"},
    {"id": "onsite", "type": "flow.stage_task_candidate", "title": "现场检查与采样取证"},
    {"id": "scan", "type": "gateway.communication_draft", "title": "材料扫描/PDF识别/证据数字化"},
    {"id": "evidence_chain", "type": "object.business_schema", "title": "证据链归集"},
    {"id": "evidence_review", "type": "judgment.ai", "title": "证据三性审查（真实性/合法性/关联性）", "gate_policy": {"required_gate": "ai_judgment_gate", "pending_owner_confirmation": true}},
    {"id": "fact_advice", "type": "collaboration.advice", "title": "违法事实候选", "slot_ref": "enforcement_elite", "candidate_type": "AdviceCandidate"},
    {"id": "legal_advice", "type": "collaboration.advice", "title": "法律依据候选（按领域+案发时点择法）", "slot_ref": "enforcement_elite", "candidate_type": "AdviceCandidate"},
    {"id": "lawyer_challenge", "type": "collaboration.challenge", "title": "挑剔律师质询（证据三性+程序瑕疵）", "slot_ref": "critical_lawyer"},
    {"id": "compare", "type": "collaboration.compare_gate", "title": "多角色对照确认门", "gate_policy": {"required_gate": "role_compare_gate", "pending_owner_confirmation": true}},
    {"id": "disposition_shadow", "type": "simulation.futureshadow", "title": "处置后果未来投影推演（责令改正/处罚/移送对比）"},
    {"id": "disposition", "type": "judgment.rule", "title": "责令改正/行政处罚/查封扣押/移送分支"},
    {"id": "correction_task", "type": "flow.stage_task_candidate", "title": "责令改正/处罚执行任务候选"},
    {"id": "doc_draft", "type": "gateway.communication_draft", "title": "执法文书草稿（责令改正/处罚决定书等）"},
    {"id": "owner_gate", "type": "policy.gate_config", "title": "Owner 主权确认 + Base Gate 裁定", "gate_policy": {"required_gate": "enforcement_doc_gate", "pending_owner_confirmation": true}},
    {"id": "archive", "type": "receipt.link", "title": "Receipt 归档（全过程可回放）"},
    {"id": "done", "type": "flow.end", "title": "案件收口"}
  ],
  "edges": [
    {"id": "e1", "source": "intake", "target": "screening"},
    {"id": "e2", "source": "screening", "target": "inspect_prep", "condition": "current_state == 立案"},
    {"id": "e2_pdf", "source": "screening", "target": "inspect_prep", "condition": "pdf_parse_status == parsed"},
    {"id": "e3", "source": "inspect_prep", "target": "credentials"},
    {"id": "e4", "source": "credentials", "target": "onsite"},
    {"id": "e5", "source": "onsite", "target": "scan"},
    {"id": "e6", "source": "scan", "target": "evidence_chain"},
    {"id": "e7", "source": "evidence_chain", "target": "evidence_review"},
    {"id": "e8", "source": "evidence_review", "target": "fact_advice"},
    {"id": "e9", "source": "fact_advice", "target": "legal_advice"},
    {"id": "e10", "source": "legal_advice", "target": "lawyer_challenge"},
    {"id": "e11", "source": "lawyer_challenge", "target": "compare"},
    {"id": "e12", "source": "compare", "target": "disposition_shadow", "condition": "approved"},
    {"id": "e12_shadow", "source": "disposition_shadow", "target": "disposition"},
    {"id": "e13", "source": "disposition", "target": "correction_task", "condition": "current_state contains 责令改正"},
    {"id": "e13_pdf", "source": "disposition", "target": "correction_task", "condition": "disposition_status contains correction_order"},
    {"id": "e14", "source": "correction_task", "target": "doc_draft"},
    {"id": "e15", "source": "doc_draft", "target": "owner_gate"},
    {"id": "e16", "source": "owner_gate", "target": "archive", "condition": "approved"},
    {"id": "e17", "source": "archive", "target": "done"}
  ]
}
