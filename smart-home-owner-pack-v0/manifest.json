{
  "pack_id": "pack_smart_home_owner_v0",
  "pack_ref": "scene_pack://smart-home-owner-project-ops",
  "version": "1.0.0",
  "name": "智能家居老板项目经营 Pack",
  "template_family": "长周期项目交付型",
  "description": "面向智能家居/智能装修公司老板的客户项目经营全周期场景荚：从项目机会录入 → Frappe 项目/客户快照 → 项目经理经营建议 → 里程碑/采购/施工任务候选 → 客户沟通草稿 → Frappe 写回候选 → Owner/Base 经营确认门 → 项目回执归档。Frappe 仅作 provider 需求声明，真实读写经 04/11 网关候选 + Base/Receipt。",
  "author": "Truzhen Pack Studio",
  "pack_type": "domain_work_pack",
  "manifest_version": "v3",
  "target_industry": "智能家居 / 智能装修 / 长周期项目交付",
  "target_audience": "智能家居公司老板、项目经理、客服与交付团队",
  "flow_spec_ref": "scene_flow_spec:smart-home-owner-project-ops-flow@1.0.0",
  "flow_file": "flows/smart-home-owner-project-ops-flow.flow.json",
  "role_slots_file": "role-slots/role-slots.json",
  "capabilities_file": "capabilities/capabilities.json",
  "security_profile": {
    "candidate_only": true,
    "non_formal": true,
    "requires_base_gate": true,
    "requires_receipt_candidate": true,
    "default_provider_mode": "disabled",
    "no_real_send": true,
    "no_real_execute": true,
    "no_real_model_call": false,
    "isolated_namespace": "smart_home_owner_ns"
  },
  "role_slots": [
    {
      "slot_id": "smart_home_project_manager",
      "responsibility": "智能家居项目经理：需求澄清/里程碑/风险/下一步候选（Proposer）",
      "node_type": "advice",
      "default_role_pack_ref": "role_pack://smart-home-project-manager"
    }
  ],
  "capabilities_required": [
    "project_external_snapshot",
    "customer_relationship_snapshot",
    "project_milestone_write_candidate"
  ],
  "required_capabilities": [],
  "gates": {
    "project_gate": "smart_home_project_gate",
    "state_transition_gate": "base_gate"
  },
  "gate_flags": [
    "project_milestone_confirm",
    "frappe_write_confirm",
    "customer_send_confirm"
  ],
  "receipt_policy": {
    "ledger_group": "smart_home_owner_project",
    "append_only": true,
    "requires_witness": true
  },
  "person_strategy": {
    "summary": "判人策略：项目经理为 Proposer（只出经营建议、任务候选、沟通草稿、写回候选，无正式裁定权）；报价、合同、采购、施工排期、对外承诺、Frappe 写回属高风险正式动作，一律回 Owner + Base Gate 裁定。",
    "proposer_roles": [
      "smart_home_project_manager"
    ],
    "high_risk_actions_return_to_owner": [
      "project_milestone_confirm",
      "frappe_write_confirm",
      "customer_send_confirm"
    ],
    "delegation_allowed": false
  },
  "formalization_requirement": {
    "summary": "判事策略：项目建模、快照读取、经营建议、任务/沟通草稿、写回候选均为候选态；唯有里程碑/采购/施工正式任务、对外发送、Frappe 写回、回执归档需经 Owner 主权确认 + Base Gate 裁定后才正式化。裁定权在 Base，不在场景包。",
    "formalizes": [
      "FormalTask",
      "ProjectMilestone",
      "CommunicationSend",
      "FrappeWrite",
      "FormalReceipt"
    ],
    "decided_by": "owner_plus_base_gate"
  },
  "provider_requirements": [
    {
      "requirement_id": "frappe_project_snapshot",
      "capability": "project_external_snapshot",
      "gateway_class": "execution",
      "risk_class": "low",
      "binding": "registry_to_gateway_to_base",
      "fallback_policy": "provider_missing",
      "provider_family": "frappe"
    },
    {
      "requirement_id": "frappe_customer_snapshot",
      "capability": "customer_relationship_snapshot",
      "gateway_class": "execution",
      "risk_class": "low",
      "binding": "registry_to_gateway_to_base",
      "fallback_policy": "provider_missing",
      "provider_family": "frappe"
    },
    {
      "requirement_id": "frappe_project_write_candidate",
      "capability": "project_milestone_write_candidate",
      "gateway_class": "execution",
      "risk_class": "medium",
      "binding": "registry_to_gateway_to_base",
      "fallback_policy": "blocked",
      "provider_family": "frappe"
    }
  ],
  "notification_command_report_routes": {
    "notification": [
      "owner_project_review_inbox",
      "project_transaction_timeline"
    ],
    "command_candidate": [
      "create_project_task_candidate",
      "draft_customer_followup",
      "prepare_frappe_project_write_candidate",
      "request_owner_project_gate"
    ],
    "report": [
      "project_transaction_timeline",
      "receipt_ledger",
      "frappe_snapshot_review"
    ]
  },
  "multi_role_comparison": {
    "summary": "本 pack 单角色（项目经理）经 advice 节点出候选，正式动作回 owner_gate；无多角色对照，无 runtime 内隐藏 agent 回路。",
    "explicit_nodes": [
      "manager_advice(smart_home_project_manager/advice)"
    ],
    "hidden_agent_loops_forbidden": true
  },
  "moat_justification": {
    "question": "用户能否一句话让最强模型直接做出同样结果？",
    "passes_moat": true,
    "valid_reasons": [
      "real_system_integration",
      "auditable_evidence_receipt",
      "transaction_lifecycle_replay"
    ],
    "rationale": "智能家居项目经营需要项目事务生命周期、Frappe 外部项目快照、写回候选、Owner/Base Gate 和 Receipt 回放；一句话模型只能给建议，不能形成可审计、可回滚、可挂事务对象的经营 Pack。"
  },
  "ui_surface_slots": [
    "pod",
    "object",
    "capsule",
    "candidate",
    "execution",
    "receipt",
    "setting"
  ],
  "forbidden_artifacts": [
    "node_modules",
    "dist",
    "build",
    ".vite",
    "*.db",
    "*.sqlite",
    "*.log",
    "*.jsonl"
  ]
}