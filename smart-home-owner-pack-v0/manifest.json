{
  "pack_id": "pack_smart_home_owner_v0",
  "pack_ref": "scene_pack://smart-home-owner-project-ops",
  "version": "1.1.0",
  "lifecycle_status": "已接线",
  "name": "智能家居老板项目经营 Pack",
  "template_family": "长周期项目交付型",
  "description": "面向智能家居/智能装修公司老板的单项目完整经营周期场景荚：商机 → 立项 → 进度 → 物料 → 交付 → 历史查询。Frappe 仅作受控项目 Provider；设备控制不自造程序，仅可选引用 Home Assistant Provider。所有写入与设备动作均先形成候选，经 Owner + Base Gate、Gateway 和 Receipt；Provider 缺失时诚实返回 provider_missing/not_ready/blocked。",
  "author": "Truzhen Pack Studio",
  "pack_type": "domain_work_pack",
  "kind": "scene_pack",
  "min_truzhen_version": "3.0.0",
  "manifest_version": "v3",
  "target_industry": "智能家居 / 智能装修 / 长周期项目交付",
  "target_audience": "智能家居公司老板、项目经理、客服与交付团队",
  "flow_spec_ref": "scene_flow_spec:smart-home-owner-project-ops-flow@1.1.0",
  "flow_file": "flows/smart-home-owner-project-ops-flow.flow.json",
  "role_slots_file": "role-slots/role-slots.json",
  "capabilities_file": "capabilities/capabilities.json",
  "security_profile": {
    "candidate_only": true,
    "non_formal": true,
    "requires_base_gate": true,
    "requires_receipt_candidate": true,
    "default_provider_mode": "disabled",
    "no_real_send": true,
    "no_real_execute": true,
    "no_real_model_call": false,
    "isolated_namespace": "smart_home_owner_ns"
  },
  "role_slots": [
    {
      "slot_id": "smart_home_project_manager",
      "responsibility": "智能家居项目经理：商机/立项/进度/物料/交付事实澄清、风险与下一步候选（Proposer）",
      "node_type": "advice",
      "default_role_pack_ref": "role_pack://smart-home-project-manager"
    }
  ],
  "capabilities_required": [
    "project_external_snapshot",
    "customer_relationship_snapshot",
    "project_opportunity_write_candidate",
    "project_initiation_write_candidate",
    "project_progress_write_candidate",
    "project_material_write_candidate",
    "project_delivery_write_candidate"
  ],
  "required_capabilities": [],
  "gates": {
    "project_gate": "smart_home_project_gate",
    "state_transition_gate": "base_gate",
    "optional_device_action_gate": "base_execution_gate"
  },
  "gate_flags": [
    "project_opportunity_confirm",
    "project_initiation_confirm",
    "project_progress_confirm",
    "project_material_confirm",
    "project_delivery_confirm",
    "frappe_write_confirm",
    "customer_send_confirm",
    "optional_device_action_confirm"
  ],
  "receipt_policy": {
    "ledger_group": "smart_home_owner_project",
    "append_only": true,
    "requires_witness": true
  },
  "person_strategy": {
    "summary": "判人策略：项目经理为 Proposer，只能提出商机、立项、进度、物料、交付、沟通和可选设备动作候选；价格、合同、采购、施工、对外承诺、Frappe 写回与设备动作均回 Owner + Base Gate 裁定。",
    "proposer_roles": [
      "smart_home_project_manager"
    ],
    "high_risk_actions_return_to_owner": [
      "project_opportunity_confirm",
      "project_initiation_confirm",
      "project_progress_confirm",
      "project_material_confirm",
      "project_delivery_confirm",
      "frappe_write_confirm",
      "customer_send_confirm",
      "optional_device_action_confirm"
    ],
    "delegation_allowed": false
  },
  "formalization_requirement": {
    "summary": "判事策略：单项目五阶段数据、角色建议、沟通草稿、Frappe 写回和设备动作均先为 Candidate；正式任务、外部写入、发送或设备执行必须经 Owner 主权确认、Base Gate、受控 Gateway 与可反查 Receipt。裁定权在 Base，不在 Pack、角色、Frappe 或 Home Assistant。",
    "formalizes": [
      "FormalTask",
      "ProjectLifecycleRecord",
      "CommunicationSend",
      "FrappeWrite",
      "DeviceAction",
      "FormalReceipt"
    ],
    "decided_by": "owner_plus_base_gate"
  },
  "provider_requirements": [
    {
      "requirement_id": "frappe_project_snapshot",
      "capability": "project_external_snapshot",
      "gateway_class": "execution",
      "risk_class": "low",
      "binding": "registry_to_gateway_to_base",
      "fallback_policy": "provider_missing",
      "provider_family": "frappe"
    },
    {
      "requirement_id": "frappe_customer_snapshot",
      "capability": "customer_relationship_snapshot",
      "gateway_class": "execution",
      "risk_class": "low",
      "binding": "registry_to_gateway_to_base",
      "fallback_policy": "provider_missing",
      "provider_family": "frappe"
    },
    {
      "requirement_id": "frappe_project_lifecycle_write_candidate",
      "capability": "project_lifecycle_write_candidate",
      "gateway_class": "execution",
      "risk_class": "medium",
      "binding": "registry_to_gateway_to_base",
      "fallback_policy": "blocked",
      "provider_family": "frappe"
    },
    {
      "requirement_id": "home_assistant_device_control_candidate",
      "capability": "smart_home_device_control_candidate",
      "gateway_class": "execution",
      "risk_class": "high",
      "binding": "registry_to_gateway_to_base",
      "fallback_policy": "not_ready",
      "provider_family": "home_assistant",
      "optional": true,
      "scope": "测试实体与 Owner 明确授权的受控设备；必须展示 entity/action/impact，禁止 Pack 直连"
    }
  ],
  "notification_command_report_routes": {
    "notification": [
      "owner_project_review_inbox",
      "project_transaction_timeline"
    ],
    "command_candidate": [
      "create_project_opportunity_candidate",
      "create_project_initiation_candidate",
      "create_project_progress_candidate",
      "create_project_material_candidate",
      "create_project_delivery_candidate",
      "draft_customer_followup",
      "prepare_frappe_project_write_candidate",
      "prepare_optional_home_assistant_action_candidate",
      "request_owner_project_gate"
    ],
    "report": [
      "project_transaction_timeline",
      "receipt_ledger",
      "frappe_snapshot_review",
      "project_history_query"
    ]
  },
  "multi_role_comparison": {
    "summary": "本 Pack 单角色（项目经理）经 advice 节点提出候选，五阶段写回与可选设备动作分别回 Owner/Base Gate；无 runtime 内隐藏 agent 回路。",
    "explicit_nodes": [
      "manager_advice(smart_home_project_manager/advice)"
    ],
    "hidden_agent_loops_forbidden": true
  },
  "moat_justification": {
    "question": "用户能否一句话让最强模型直接做出同样结果？",
    "passes_moat": true,
    "valid_reasons": [
      "real_system_integration",
      "auditable_evidence_receipt",
      "transaction_lifecycle_replay"
    ],
    "rationale": "智能家居项目经营需要单项目五阶段事务生命周期、Frappe 外部快照与受控写回、可选 Home Assistant 设备能力、Owner/Base Gate 和 Receipt 回放；一句话模型不能形成可审计、可重试、可查询历史且不腐化基座的闭环。"
  },
  "ui_surface_slots": [
    "pod",
    "object",
    "capsule",
    "candidate",
    "execution",
    "receipt",
    "setting"
  ],
  "forbidden_artifacts": [
    "node_modules",
    "dist",
    "build",
    ".vite",
    "*.db",
    "*.sqlite",
    "*.log",
    "*.jsonl",
    "__pycache__",
    "*.pyc"
  ],
  "software_requirements": [
    {
      "requirement_id": "frappe-runtime",
      "software_family": "frappe-erpnext-stack",
      "provider_family": "frappe",
      "version_range": ">=16.0.0,<17.0.0",
      "required_capabilities": [
        "project_external_snapshot",
        "customer_relationship_snapshot",
        "project_lifecycle_write_candidate"
      ],
      "license_policy": "review_required",
      "isolation_policy": "reuse_preferred",
      "fallback_policy": "provider_missing",
      "gateway_class": "execution",
      "risk_class": "medium"
    },
    {
      "requirement_id": "home-assistant-runtime",
      "software_family": "home-assistant-core",
      "provider_family": "home_assistant",
      "version_range": ">=2025.0.0,<2027.0.0",
      "required_capabilities": [
        "smart_home_device_state_snapshot",
        "smart_home_device_control_candidate"
      ],
      "license_policy": "review_required",
      "isolation_policy": "reuse_preferred",
      "fallback_policy": "not_ready",
      "gateway_class": "execution",
      "risk_class": "high",
      "optional": true
    },
    {
      "requirement_id": "baserow-runtime-a",
      "software_family": "baserow-family",
      "provider_family": "baserow",
      "version_range": ">=2.2.0,<2.3.0",
      "required_capabilities": [
        "structured_table_storage",
        "workflow_record_snapshot"
      ],
      "license_policy": "review_required",
      "isolation_policy": "reuse_preferred",
      "fallback_policy": "provider_missing",
      "gateway_class": "execution",
      "risk_class": "medium"
    },
    {
      "requirement_id": "shared-document-ocr",
      "software_family": "pdf-ocr-family",
      "provider_family": "pdf_ocr",
      "version_range": ">=1.0.0,<2.0.0",
      "required_capabilities": [
        "document_ocr"
      ],
      "license_policy": "review_required",
      "isolation_policy": "reuse_preferred",
      "fallback_policy": "manual_handoff",
      "gateway_class": "execution",
      "risk_class": "medium"
    }
  ]
}
