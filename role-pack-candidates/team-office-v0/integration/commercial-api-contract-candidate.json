      "target_endpoint": "signed_download_create",
      "required_correlation_keys": [
        "correlation_id",
        "entitlement_ref",
        "artifact_ref",
        "artifact_sha256"
      ],
      "required_evidence": "entitlement_ref + download_receipt_ref + signed_download_ref"
    },
    {
      "handoff_id": "download_to_install",
      "source_endpoint": "signed_download_create",
      "target_endpoint": "local_install_request",
      "required_correlation_keys": [
        "correlation_id",
        "signed_download_ref",
        "download_receipt_ref",
        "entitlement_ref",
        "artifact_sha256"
      ],
      "required_evidence": "download_receipt_ref + install_receipt_ref + artifact_hash_verification_ref"
    },
    {
      "handoff_id": "install_to_team_settings",
      "source_endpoint": "local_install_request",
      "target_endpoint": "team_settings_installed_roles_refresh",
      "required_correlation_keys": [
        "correlation_id",
        "install_receipt_ref",
        "enabled_role_pack_version",
        "artifact_sha256"
      ],
      "required_evidence": "install_receipt_ref + installed_role_catalog_ref + replaceable_slot_refs"
    },
    {
      "handoff_id": "promotion_gate_to_production_controls",
      "source_endpoint": "production_go_live_request",
      "target_endpoint": "production_listing_publish_request",
      "required_correlation_keys": [
        "correlation_id",
        "production_promotion_gate_ref",
        "owner_go_no_go_decision_ref",
        "bundle_tree_sha256"
      ],
      "required_evidence": "production_promotion_gate_ref + owner_go_no_go_decision_ref + production_go_live_request_receipt_ref + production_listing_publish_request_receipt_ref"
    }
  ],
  "forbidden": [
    "real_payment_capture_without_owner_authorization",
    "production_publish_without_owner_authorization",
    "download_without_entitlement",
    "install_without_hash_verification",
    "frontend_success_without_receipt_ref",
    "cloud_payment_truth_in_truzhen_packs",
    "store_signed_download_secret_in_pack",
    "team_role_binding_without_owner_gate"
  ],
