        "production_publish_without_owner_authorization",
        "store_raw_secret"
      ]
    },
    "listing_draft_request": {
      "truth_source": "truzhen-cloud",
      "required_inputs": [
        "upload_receipt_candidate_ref",
        "display_name",
        "version",
        "risk_statement",
        "price_candidate",
        "license_candidate"
      ],
      "success_status": "listing_draft_candidate",
