  "pass_fail_algorithm": {
    "normal_commercialization_pass_allowed_now": false,
    "required_all": [
      "user_view_gui_evidence_for_every_stage",
      "cloud_upload_receipt",
      "listing_draft_ref",
      "sandbox_payment_receipt",
      "entitlement_ref",
      "download_receipt",
      "download_hash_matches_upload",
      "install_receipt",
      "enabled_role_pack_version_ref",
      "team_binding_receipt",
      "negative_cases_blocked",
      "independent_acceptance_signoff",
      "owner_go_no_go_decision"
    ],
    "allowed_output_decisions": [
      "passed_verified",
      "blocked_missing_authoritative_evidence",
      "failed_requires_issue",
      "not_run"
    ],
    "decision_rule": "只有 required_all 全部有权威证据且无 open P0-P11 blocker 时，才可输出 passed_verified；否则必须输出 blocked_missing_authoritative_evidence 或 failed_requires_issue。"
