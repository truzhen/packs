      "expected_status": "blocked_entitlement_missing",
      "truth_source": "truzhen-cloud",
      "required_block_evidence": "gui_screenshot_path + cloud_block_receipt_ref + entitlement_missing_reason"
    },
    "tampered_artifact_hash": {
      "expected_status": "blocked_artifact_hash_mismatch",
      "truth_source": "truzhenos",
      "required_block_evidence": "gui_screenshot_path + artifact_hash_block_receipt_ref + expected_actual_hash_pair"
    },
