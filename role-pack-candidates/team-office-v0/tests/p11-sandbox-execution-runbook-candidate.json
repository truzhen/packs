  "forbidden": [
    "direct_api_call_as_user_action",
    "manual_json_edit_as_success",
    "real_payment_capture",
    "production_publish",
    "raw_voice_or_vrm_upload",
    "store_secret_or_signed_url",
    "claim_complete_without_independent_acceptance",
    "claim_cloud_success_without_install_receipt"
