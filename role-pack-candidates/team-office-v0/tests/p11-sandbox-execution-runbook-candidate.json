  "hash_continuity_check": {
    "required": true,
    "bundle_tree_sha256_source": "commerce/artifact-bundle-digest-candidate.json",
    "upload_receipt_ref": "truzhen-cloud_upload_receipt",
    "download_receipt_ref": "truzhen-cloud_download_receipt",
    "install_receipt_ref": "truzhenos_install_receipt",
    "mismatch_result": "failed_requires_issue"
  },
  "rollback_and_cleanup_policy": {
    "sandbox_cleanup_only": true,
    "do_not_delete_receipts": true,
    "do_not_rewrite_team_history": true,
    "cleanup_requires_receipt": true,
    "production_data_cleanup_forbidden": true
