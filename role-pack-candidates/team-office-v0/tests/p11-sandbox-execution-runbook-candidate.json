      "p11_verification_record",
      "e2e_run_record",
      "receipt_index",
      "screenshot_index",
      "hash_continuity_report",
      "negative_case_report",
      "independent_acceptance_signoff",
      "owner_go_no_go_decision",
      "production_promotion_receipts"
    ],
