{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "candidate_only",
    "business_skill_id",
    "title",
    "channels",
    "evidence_refs",
    "metrics_summary",
    "decisions",
    "uncertainties",
    "owner_judgement_items",
    "cta",
    "publish_ready"
  ],
  "properties": {
    "schema_version": {"type": "string", "enum": ["content_ops_model_candidate/v1"]},
    "candidate_only": {"type": "boolean", "enum": [true]},
    "business_skill_id": {"type": "string", "enum": ["content_ops.weekly_review"]},
    "title": {"type": "string", "minLength": 1},
    "channels": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "evidence_refs": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "metrics_summary": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "decisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["item", "decision", "reason"],
        "properties": {
          "item": {"type": "string", "minLength": 1},
          "decision": {"type": "string", "enum": ["keep", "change", "stop"]},
          "reason": {"type": "string", "minLength": 1}
        }
      }
    },
    "uncertainties": {"type": "array", "items": {"type": "string"}},
    "owner_judgement_items": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "cta": {"type": "string", "minLength": 1},
    "publish_ready": {"type": "boolean", "enum": [false]}
  }
}
