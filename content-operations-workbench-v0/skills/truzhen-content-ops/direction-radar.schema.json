{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "candidate_only",
    "business_skill_id",
    "title",
    "directions",
    "uncertainties",
    "cta",
    "publish_ready"
  ],
  "properties": {
    "schema_version": {"type": "string", "enum": ["content_ops_model_candidate/v1"]},
    "candidate_only": {"type": "boolean", "enum": [true]},
    "business_skill_id": {"type": "string", "enum": ["content_ops.direction_radar"]},
    "title": {"type": "string", "minLength": 1},
    "directions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["audience_problem", "evidence_refs", "risk", "channels", "owner_judgement_items"],
        "properties": {
          "audience_problem": {"type": "string", "minLength": 1},
          "evidence_refs": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "risk": {"type": "string", "minLength": 1},
          "channels": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "owner_judgement_items": {"type": "array", "minItems": 1, "items": {"type": "string"}}
        }
      }
    },
    "uncertainties": {"type": "array", "items": {"type": "string"}},
    "cta": {"type": "string", "minLength": 1},
    "publish_ready": {"type": "boolean", "enum": [false]}
  }
}
